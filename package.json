    "todo"
  ],
  "license": "MIT",
  "author": "Ashish Dhiman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aashishd/pi-task-tracker.git"
  },
  "homepage": "https://github.com/aashishd/pi-task-tracker#readme",
  "bugs": {
    "url": "https://github.com/aashishd/pi-task-tracker/issues"
  },
  "files": [
